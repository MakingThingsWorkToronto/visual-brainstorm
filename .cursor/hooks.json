{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "matcher": "Task|MCP:present_board|MCP:present_gallery|MCP:capture_artifact|MCP:ask_concierge|MCP:compose_poster|MCP:load_discussion",
        "command": "node scripts/pipe-progress.mjs"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node scripts/check-agentic-surface.mjs --hook"
      }
    ],
    "subagentStop": [
      {
        "command": "node scripts/pipe-progress.mjs"
      }
    ],
    "stop": [
      {
        "command": "node scripts/pipe-progress.mjs"
      }
    ]
  }
}
