{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent|Task|mcp__visual-brainstorm__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/pipe-progress.mjs\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/pipe-progress.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/pipe-progress.mjs\""
          }
        ]
      }
    ]
  }
}
