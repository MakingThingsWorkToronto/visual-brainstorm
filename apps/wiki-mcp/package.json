{
  "name": "@visual-brainstorm/wiki-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only stdio MCP server exposing the repo's authoritative wiki/ to Claude Code with context-shaped search and granular per-heading reads.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "visual-brainstorm-wiki-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4"
  }
}
