{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent|Task|mcp__visual-brainstorm__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/pipe-progress.mjs"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-agentic-surface.mjs --hook"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-copilot-parity.mjs --hook"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/pipe-progress.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/pipe-progress.mjs"
          }
        ]
      }
    ]
  }
}
